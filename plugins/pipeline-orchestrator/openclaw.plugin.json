{
  "id": "pipeline-orchestrator",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "repo": {
        "type": "string",
        "description": "GitHub repo (owner/name)"
      },
      "projectPath": {
        "type": "string",
        "description": "Local path to the project"
      },
      "intervalSec": {
        "type": "number",
        "description": "Orchestration interval in seconds"
      },
      "maxWip": {
        "type": "number",
        "description": "Maximum work-in-progress issues"
      },
      "defaultWorker": {
        "type": "string",
        "enum": ["claude", "codex"],
        "description": "Default worker for issue implementation"
      },
      "cooldownMinutes": {
        "type": "number",
        "description": "Cooldown between worker invocations"
      },
      "notifyEnabled": {
        "type": "boolean"
      }
    },
    "required": ["repo", "projectPath"]
  }
}
